<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= clase.nombre_clase %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/dashboard.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid px-0">
            <div class="navbar-inner d-flex align-items-center position-relative w-100">
                <button class="btn btn-light border-0 text-dark" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                <div class="navbar-actions d-flex align-items-center gap-3 ms-auto">
                    <a href="#" class="nav-action text-dark small d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#joinModal">
                        <i class="fa-solid fa-link"></i>
                        <span>Unirse a una clase</span>
                    </a>
                    <a href="#" class="nav-action text-dark small d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createModal">
                        <i class="fa-solid fa-plus"></i>
                        <span>Crea una clase</span>
                    </a>
                    <div class="dropdown">
                        <button class="btn avatar-circle" data-bs-toggle="dropdown" aria-expanded="false">
                            <% if (user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-image">
                            <% } else { %>
                                <span class="avatar-fallback"><%= user && user.nombre ? user.nombre.charAt(0).toUpperCase() : '?' %></span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/perfil"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/dashboard" class="d-flex align-items-center gap-2 text-decoration-none">
                <img src="/public/img/maxgradeplacapng.png" alt="Logo MaxGrade" class="sidebar-logo">
                <div>
                    <div class="brand-title">MaxGrade</div>
                </div>
            </a>
        </div>
        <ul class="sidebar-menu">
            <li>Realiza click en el boton deseado para ir a donde desees:</li>
            <li><a href="/dashboard" class="sidebar-link active"><i class="fa-solid fa-graduation-cap me-3"></i>Mis clases</a></li>
            <li><a href="/clase/<%= clase.id %>/tareas" class="sidebar-link"><i class="fa-solid fa-clipboard-list me-3"></i>Tareas</a></li>
            <li><a href="/clase/<%= clase.id %>/entregadas" class="sidebar-link"><i class="fa-solid fa-clipboard-check me-3"></i>Entregadas</a></li>
        </ul>
        <div class="sidebar-footer">
            <button class="video-action" type="button" aria-label="Ver video">
                <i class="fa-solid fa-play"></i>
                <span>Click para ver el tutorial</span>
            </button>
        </div>
    </aside>

    <main class="main-content container py-4">
        <div class="page-header-card position-relative overflow-hidden mb-4" style="background: linear-gradient(135deg, #3ee67a 0%, #1a9b4a 100%);">
            <% if (clase.portada_url) { %>
                <div style="background-image: url('<%= clase.portada_url %>'); background-size: cover; background-position: center; opacity: 0.16; position: absolute; inset: 0;"></div>
            <% } %>
            <div class="position-relative p-4 p-lg-5 text-white">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
                    <div>
                        <p class="text-uppercase small fw-semibold opacity-85 mb-2">Clase</p>
                        <h1 class="display-6 fw-bold mb-2"><%= clase.nombre_clase %></h1>
                        <p class="mb-3 opacity-85 fs-5"><%= clase.seccion %></p>
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <span class="badge bg-white text-dark rounded-pill py-2 px-3">Código: <strong><%= clase.codigo_acceso || '---' %></strong></span>
                            <% if (clase.profesor) { %>
                                <span class="badge bg-white text-dark rounded-pill py-2 px-3">Profesor: <%= clase.profesor.nombre %> <%= clase.profesor.apellido || '' %></span>
                            <% } %>
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-start align-items-lg-end gap-2">
                        <a href="/clase/<%= clase.id %>/tareas" class="btn btn-light btn-sm rounded-pill px-4">Ver tareas</a>
                        <a href="/clase/<%= clase.id %>/personas" class="btn btn-outline-light btn-sm rounded-pill px-4">Personas</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row gx-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-4 gap-3">
                            <div>
                                <h2 class="h5 fw-bold mb-1">Tareas</h2>
                                <p class="mb-0 text-muted">Haz clic sobre cualquier tarea para abrirla.</p>
                            </div>
                            <% const tareaPosts = posts.filter(post => post.tipo === 'tarea'); %>
                            <span class="badge bg-primary bg-opacity-10 text-primary py-2 px-3"><%= tareaPosts.length %> pendientes</span>
                        </div>
                        <% if (!tareaPosts || tareaPosts.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="fa-solid fa-clipboard-list fa-3x text-muted opacity-25 mb-3"></i>
                                <p class="text-muted mb-0">No hay tareas activas por el momento.</p>
                            </div>
                        <% } else { %>
                            <div class="d-grid gap-3">
                                <% tareaPosts.forEach(post => { %>
                                    <a href="/tarea/<%= post.id %>" class="task-button d-flex align-items-center justify-content-between text-decoration-none">
                                        <div>
                                            <div class="fw-bold text-dark mb-1"><%= post.titulo || 'Tarea sin título' %></div>
                                            <p class="mb-0 text-muted"><%= post.descripcion || 'Revisa los detalles de la tarea aquí.' %></p>
                                        </div>
                                        <span class="btn btn-sm btn-primary rounded-pill">Ir</span>
                                    </a>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body">
                        <h3 class="h6 fw-bold mb-3">Anuncios recientes</h3>
                        <% const announcementPosts = posts.filter(post => post.tipo !== 'tarea'); %>
                        <% if (!announcementPosts || announcementPosts.length === 0) { %>
                            <div class="text-muted">No hay anuncios recientes.</div>
                        <% } else { %>
                            <div class="list-group list-group-flush">
                                <% announcementPosts.forEach(post => { %>
                                    <div class="list-group-item border-0 px-0 py-3">
                                        <div class="d-flex align-items-start gap-3 mb-2">
                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                                <i class="fa-solid fa-bullhorn"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold"><%= post.autor ? (post.autor.nombre + ' ' + (post.autor.apellido || '')) : 'MaxGrade' %></div>
                                                <small class="text-muted"><%= post.fecha_orden ? new Date(post.fecha_orden).toLocaleDateString() : '' %></small>
                                            </div>
                                        </div>
                                        <div class="mb-1 fw-semibold"><%= post.titulo || 'Anuncio' %></div>
                                        <p class="small text-muted mb-0"><%= post.descripcion || post.contenido || '' %></p>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h3 class="h6 fw-bold mb-3">Acciones rápidas</h3>
                    <a href="/clase/<%= clase.id %>/tareas" class="btn btn-primary w-100 rounded-pill mb-3">Ver todas las tareas</a>
                    <a href="/clase/<%= clase.id %>/personas" class="btn btn-outline-secondary w-100 rounded-pill">Ver personas</a>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/dashboard.js"></script>
    <script src="/public/js/clase.js"></script>
    <%- include('modals/classModals') %>
</body>
</html>
